# Public site URL (no trailing slash). Used for canonical URLs, Open Graph, and JSON-LD.
# Example: https://www.yourdomain.com
NEXT_PUBLIC_SITE_URL=

# Clerk + Convex setup
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Must match the deployment you push to (run `npx convex dev` or `npx convex deploy` after schema/function changes).
NEXT_PUBLIC_CONVEX_URL=

# Issuer for Convex auth = Clerk "Frontend API URL" (Convex Dashboard → Environment Variables).
# You can set either name; Convex auth.config accepts both. In Clerk, activate:
# https://dashboard.clerk.com/apps/setup/convex — required or /tokens/convex returns 404.
CLERK_JWT_ISSUER_DOMAIN=
# CLERK_FRONTEND_API_URL=

# Only this Clerk user ID can access /admin/blog. Set in Vercel AND in Convex Dashboard (Convex
# functions read ADMIN_CLERK_USER_ID on the server).
ADMIN_CLERK_USER_ID=
